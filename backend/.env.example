# Google Sheets — service account auth
GOOGLE_SERVICE_ACCOUNT_JSON=     # base64-encoded service account JSON
INTRANET_CONTROL_SHEET_ID=

# Google Drive — OAuth (service accounts can't own files in personal Drive)
# Run `node oauth-bootstrap.js` once to mint GOOGLE_OAUTH_REFRESH_TOKEN.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
DRIVE_SUBMISSIONS_FOLDER_ID=

# Auth
PIN_LENGTH_MIN=4
PIN_LENGTH_MAX=6
SKILL_NOTIFY_SECRET=              # shared secret for /admin/notify

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=RAC Hub <noreply@example.com>
ADMIN_NOTIFY_EMAIL=it@rirratjingu.com

# Server
PORT=3000
# CORS allow-list. Comma-separated for multiple origins.
# Local dev: leave empty to reflect any origin.
# Prod:      set to the deployed PWA URL, e.g. https://rac-hub-pwa.up.railway.app
# Mixed:     comma-separate, e.g. https://prod-pwa,http://localhost:8081
ALLOWED_ORIGIN=

# Deep link target used in admin notification emails. Typically the same
# origin as ALLOWED_ORIGIN (the PWA). Local dev: http://localhost:8081
PWA_URL=
